{
  "manifest_version": 3,
  "name": "SABAI Decrypt",
  "version": "1.0.0",
  "description": "Decrypts BYOS-encrypted supplier and buyer names on the Sabai365 web portal and Gmail. Your decryption key never leaves your browser.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.sabai365.ai/*",
        "https://365.sabai.group/*",
        "http://localhost:5173/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
